// FILM_DB_END

function lookupFromDB(film){
  const entry=FILM_DB[film.name+'||'+film.year];
  if(!entry) return null;
  const parts=entry.split('|');
  return{
    director:parts[0]||null,
    writers:parts[1]?parts[1].split(','):[],
    actors:parts[2]?parts[2].split(','):[],
    genres:parts[3]?parts[3].split(','):[]
  };
}

// ─── State ────────────────────────────────────────────────────────────────────
const STATE = { userName:'', selectedFiles:[], currentCat:'directors',
  directors:[], writers:[], actors:[], genres:[],
  runId:0, abortController:null, _dbMisses:0 };

// ─── Routing ──────────────────────────────────────────────────────────────────
function showPage(id){ document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.getElementById(id).classList.add('active'); window.scrollTo(0,0); }

// ─── Config ───────────────────────────────────────────────────────────────────
let configOpen=false;
function toggleConfig(force){ configOpen=force!==undefined?force:!configOpen; document.getElementById('config-panel').style.display=configOpen?'block':'none'; document.getElementById('config-chevron').textContent=configOpen?'▾':'▸'; }
function saveKey(t){ const v=document.getElementById(t+'-key-input').value.trim(); if(!v)return; localStorage.setItem('cmr_'+t,v); document.getElementById(t+'-saved-badge').style.display='inline'; updateConfigBadge(); }
function clearKey(t){ localStorage.removeItem('cmr_'+t); document.getElementById(t+'-key-input').value=''; document.getElementById(t+'-saved-badge').style.display='none'; updateConfigBadge(); }
function getKey(t){ return localStorage.getItem('cmr_'+t)||''; }
function updateConfigBadge(){
  const hasTMDB=!!getKey('tmdb');
  const dbSize=Object.keys(FILM_DB).length;
  const el=document.getElementById('config-status-badge');
  if(dbSize>0&&hasTMDB){
    el.innerHTML='<span style="color:#4a9a4a;font-size:11px;margin-left:6px">● DB ('+dbSize.toLocaleString()+' films) + TMDB fallback</span>';
  } else if(dbSize>0){
    el.innerHTML='<span style="color:#c8a840;font-size:11px;margin-left:6px">● DB ready ('+dbSize.toLocaleString()+' films)</span>';
  } else if(hasTMDB){
    el.innerHTML='<span style="color:#4a9a4a;font-size:11px;margin-left:6px">● TMDB ready</span>';
  } else {
    el.innerHTML='<span style="color:#664444;font-size:11px;margin-left:6px">● No database or key</span>';
  }
  if(hasTMDB) document.getElementById('tmdb-saved-badge').style.display='inline';
}

// ─── CSV Parsing ──────────────────────────────────────────────────────────────
function parseCSVLine(line){ const cols=[]; let cur='',inQ=false; for(const ch of line){ if(ch==='"')inQ=!inQ; else if(ch===','&&!inQ){cols.push(cur.trim());cur='';} else cur+=ch; } cols.push(cur.trim()); return cols; }

function parseLetterboxdCSV(text){
  const lines=text.trim().split(/\r?\n/).filter(Boolean);
  if(!lines.length) throw new Error('Empty file.');
  const header=parseCSVLine(lines[0]).map(h=>h.replace(/"/g,'').toLowerCase().trim());
  const gi=k=>header.findIndex(h=>h===k);
  const nameI=gi('name'),yearI=gi('year'),ratingI=gi('rating'),rewatchI=gi('rewatch');
  if(nameI<0) throw new Error("No 'Name' column found. Upload diary.csv or ratings.csv.");
  const films=[];
  for(let i=1;i<lines.length;i++){
    const c=parseCSVLine(lines[i]);
    const name=(c[nameI]||'').replace(/"/g,'').trim(), year=parseInt(c[yearI]);
    const rating=ratingI>=0?parseFloat(c[ratingI])||0:0;
    const rewatch=rewatchI>=0&&(c[rewatchI]||'').toLowerCase().trim()==='yes';
    if(name&&year) films.push({name,year,rating,rewatch});
  }
  return films;
}

function consolidateFilms(rawFilms){
  const map={},rw={};
  for(const f of rawFilms){ const k=f.name+'||'+f.year; if(!map[k]){map[k]={name:f.name,year:f.year,rating:f.rating};rw[k]=0;} else if(f.rating>map[k].rating)map[k].rating=f.rating; if(f.rewatch)rw[k]++; }
  return Object.entries(map).map(([k,f])=>Object.assign({},f,{rewatchCount:rw[k]}));
}

// ─── TMDB Lookup ─────────────────────────────────────────────────────────────
// One call per film: search → credits → returns {director, writers, actors}
async function lookupOneTMDB(film, apiKey, signal){
  const base='https://api.themoviedb.org/3';
  const q=encodeURIComponent(film.name);
  // Search with year
  let res=await fetch(`${base}/search/movie?api_key=${apiKey}&query=${q}&year=${film.year}&language=en-US`,{signal});
  if(res.status===401) throw new Error('TMDB_AUTH');
  if(!res.ok) return null;
  let data=await res.json();
  let movie=(data.results||[])[0];
  // Retry without year if no match
  if(!movie){
    res=await fetch(`${base}/search/movie?api_key=${apiKey}&query=${q}&language=en-US`,{signal});
    if(!res.ok) return null;
    data=await res.json();
    const results=data.results||[];
    movie=results.find(r=>Math.abs(parseInt((r.release_date||'').slice(0,4))-film.year)<=1);
    if(!movie) return null;
  }
  // Credits — single call returns director + writers + cast
  res=await fetch(`${base}/movie/${movie.id}/credits?api_key=${apiKey}`,{signal});
  if(!res.ok) return null;
  const cred=await res.json();
  const crew=cred.crew||[], cast=cred.cast||[];
  const director=(crew.find(c=>c.job==='Director')||{}).name||null;
  const WRITING_JOBS=['Screenplay','Writer','Story','Original Story','Script','Adaptation'];
  const writers=[...new Set(crew.filter(c=>WRITING_JOBS.includes(c.job)).map(c=>c.name))].slice(0,3);
  const actors=cast.slice(0,10).map(c=>c.name); // store top 10, slice at scoring time per TOP_ACTORS setting
  const genres=(movie.genre_ids||[]).map(id=>TMDB_GENRES[id]).filter(Boolean);
  return {director,writers,actors,genres};
}

async function fetchCrewTMDB(films, apiKey, onProg, signal){
  const filmData={};
  let done=0, missed=0;
  for(let i=0;i<films.length;i+=TMDB_CONCURRENCY){
    if(signal?.aborted) return null;
    const batch=films.slice(i,i+TMDB_CONCURRENCY);
    let authErr=null;
    await Promise.all(batch.map(async film=>{
      try{
        const r=await lookupOneTMDB(film,apiKey,signal);
        if(r) filmData[film.name+'||'+film.year]=r;
        else missed++;
      } catch(e){
        if(e.name==='AbortError') return;
        if(e.message==='TMDB_AUTH') authErr=e;
        else { console.warn('TMDB lookup failed for',film.name,e); missed++; }
      }
      done++;
      onProg(
        Math.round(10+(done/films.length)*78),
        `TMDB: ${done} / ${films.length} films — ${done-missed} matched, ${missed} missed`
      );
    }));
    if(authErr) throw new Error('Invalid TMDB API key. Check your key in ⚙ API Key Setup.');
    if(signal?.aborted) return null;
    if(i+TMDB_CONCURRENCY<films.length) await sleep(200);
  }
  if(!Object.keys(filmData).length) return null;
  return filmData;
}

function sleep(ms){return new Promise(r=>setTimeout(r,ms));}

async function fetchCrewHybrid(films, apiKey, onProg, signal){
  // Phase 1: instant DB lookup
  const filmData={};
  const misses=[];
  for(const film of films){
    const r=lookupFromDB(film);
    if(r) filmData[film.name+'||'+film.year]=r;
    else misses.push(film);
  }
  const dbHits=films.length-misses.length;
  // Phase 2: TMDB fallback for films not in the built-in DB (requires API key)
  if(apiKey&&misses.length){
    onProg(10,`Built-in DB: ${dbHits} matched, ${misses.length} not found — fetching from TMDB…`);
    const tmdbData=await fetchCrewTMDB(misses,apiKey,onProg,signal);
    if(signal?.aborted) return null;
    if(tmdbData) Object.assign(filmData,tmdbData);
    STATE._dbMisses=misses.length-Object.keys(tmdbData||{}).length;
  } else {
    onProg(10,`Built-in DB: ${dbHits} matched${misses.length?' — '+misses.length+' not found':''}${misses.length&&!apiKey?' (add TMDB key for full coverage)':''}`);
    STATE._dbMisses=misses.length;
  }
  return Object.keys(filmData).length?filmData:null;
}

// ─── Scoring ──────────────────────────────────────────────────────────────────
function computeScores(byPerson){
  const qualified=Object.entries(byPerson).filter(([,f])=>f.length>=MIN_FILMS);
  if(!qualified.length) return [];
  const maxFilms=Math.max(...qualified.map(([,f])=>f.length));
  const maxRw=Math.max(...qualified.map(([,f])=>f.reduce((s,x)=>s+x.rewatchCount,0)),1);
  return qualified.map(([name,films])=>{
    const rated=films.filter(f=>f.rating>0);
    const avgRating=rated.length?rated.reduce((s,f)=>s+f.rating,0)/rated.length:0;
    const filmCount=films.length, rewatchCount=films.reduce((s,f)=>s+f.rewatchCount,0);
    const sorted=rated.map(f=>f.rating).sort((a,b)=>b-a);
    const top3Avg=sorted.slice(0,3).reduce((a,b)=>a+b,0)/(Math.min(3,sorted.length)||1);
    const score=WEIGHTS.avgRating*(avgRating/5)+WEIGHTS.filmCount*(filmCount/maxFilms)+WEIGHTS.rewatches*(rewatchCount/maxRw)+WEIGHTS.top3Score*(top3Avg/5);
    const topFilms=[...rated].sort((a,b)=>b.rating-a.rating).slice(0,3);
    return{name,films,filmCount,rewatchCount,avgRating,top3Avg,score,topFilms};
  }).sort((a,b)=>b.score-a.score);
}

function buildPersonMaps(films, filmData){
  const byDir={},byWriter={},byActor={},genreCount={};
  for(const f of films){
    const d=filmData[f.name+'||'+f.year];
    if(!d) continue;
    const addTo=(map,person)=>{ if(!map[person])map[person]=[]; map[person].push(f); };
    if(d.director) addTo(byDir,d.director);
    (d.writers||[]).forEach(w=>addTo(byWriter,w));
    (d.actors||[]).slice(0,TOP_ACTORS).forEach(a=>addTo(byActor,a));
    (d.genres||[]).forEach(g=>{ genreCount[g]=(genreCount[g]||0)+1; });
  }
  // Sort genres by count
  const genres=Object.entries(genreCount).sort((a,b)=>b[1]-a[1]).map(([g,n])=>({genre:g,count:n}));
  return{byDir,byWriter,byActor,genres};
}

// Rebuild raw person→films maps from scored arrays (fallback for v1/v2 cache files)
// v3+ cache files bypass this and use the stored filmData directly
function rebuildMapsFromScored(){
  STATE._byDir={};    STATE.directors.forEach(d=>{ STATE._byDir[d.name]=d.films||[]; });
  STATE._byWriter={};  STATE.writers.forEach(d=>{ STATE._byWriter[d.name]=d.films||[]; });
  STATE._byActor={};   STATE.actors.forEach(d=>{ STATE._byActor[d.name]=d.films||[]; });
  STATE._filmData=null; STATE._films=null;
  // Note: TOP_ACTORS slider won't work on v1/v2 cache — user needs to re-export
}

// ─── File Handling ────────────────────────────────────────────────────────────
function handleFileInput(files){
  const arr=Array.from(files); if(!arr.length)return;
  document.getElementById('file-input').value='';
  if(arr.some(f=>f.size>25*1024*1024)){ showError('File too large (>25 MB). Please check your export.'); return; }
  if(arr.length===1&&arr[0].name.endsWith('.json')){
    arr[0].text().then(t=>{
      try{
        const d=JSON.parse(t);
        if(!d.version||!d.directors) throw new Error('Invalid cache file.');
        STATE.userName=d.userName||'';
        STATE.genres=d.genres||[];
        // Restore scoring settings if present
        if(typeof d.minFilms==='number'){ MIN_FILMS=d.minFilms; const el=document.getElementById('sl-minFilms'); if(el){el.value=MIN_FILMS;document.getElementById('lbl-minFilms').textContent=MIN_FILMS;} }
        if(typeof d.topActors==='number'){ TOP_ACTORS=d.topActors; const el=document.getElementById('sl-topActors'); if(el){el.value=TOP_ACTORS;document.getElementById('lbl-topActors').textContent=TOP_ACTORS;} }
        // Version 3+: has raw filmData → full slider support
        if(d.version>=3 && d.filmData && d.films){
          if(!d.films.length||!Object.keys(d.filmData).length) throw new Error('Cache file has no film data.');
          STATE._filmData=d.filmData;
          STATE._films=d.films;
          const{byDir,byWriter,byActor,genres}=buildPersonMaps(d.films,d.filmData);
          STATE._byDir=byDir; STATE._byWriter=byWriter; STATE._byActor=byActor;
          if(genres.length) STATE.genres=genres;
          // Re-score with current weights/settings
          STATE.directors=computeScores(byDir);
          STATE.writers=computeScores(byWriter);
          STATE.actors=computeScores(byActor);
        } else {
          // Version 1/2: no raw data, rebuild maps from scored arrays only
          STATE.directors=d.directors||[];
          STATE.writers=d.writers||[];
          STATE.actors=d.actors||[];
          rebuildMapsFromScored();
        }
        renderResults(); showPage('page-results');
      }catch(e){showError('Could not load cache: '+e.message);}
    }); return;
  }
  STATE.selectedFiles=arr;
  const names=arr.map(f=>f.name).join(', ');
  document.getElementById('drop-label').textContent='✓ '+names;
  document.getElementById('naming-files').textContent='Files: '+names;
  const hasTMDB=!!getKey('tmdb');
  document.getElementById('lookup-badge').innerHTML=hasTMDB?'<span style="color:#4a9a4a;font-size:12px">Will use TMDB (free)</span>':'<span style="color:#c05050;font-size:12px">⚠ No TMDB key — open ⚙ Setup to add one</span>';
  document.getElementById('name-input').value=''; document.getElementById('analyze-btn').textContent='Analyze →';
  showPage('page-naming');
}

const dz=document.getElementById('drop-zone');
dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('drag');});
dz.addEventListener('dragleave',()=>dz.classList.remove('drag'));
dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('drag'); const files=Array.from(e.dataTransfer.files).filter(f=>f.name.endsWith('.csv')||f.name.endsWith('.json')); if(files.length)handleFileInput(files);});

// ─── Analysis ─────────────────────────────────────────────────────────────────
async function startAnalysis(){
  STATE.runId++;
  const thisRunId=STATE.runId;
  STATE.abortController=new AbortController();
  const signal=STATE.abortController.signal;

  STATE.userName=document.getElementById('name-input').value.trim();
  document.getElementById('proc-title').textContent=STATE.userName?`Sculpting ${STATE.userName}'s mountain…`:'Sculpting your mountain…';
  showPage('page-processing');
  try{
    let allRaw=[];
    for(const file of STATE.selectedFiles){ const text=await file.text(); allRaw=allRaw.concat(parseLetterboxdCSV(text)); }
    if(STATE.runId!==thisRunId) return;
    if(!allRaw.length) throw new Error('No films found.');
    const films=consolidateFilms(allRaw);
    upd(8,`Found ${films.length} unique films. Looking up directors, writers, and actors…`);

    const tmdbKey=getKey('tmdb');
    upd(10,`Checking built-in database for ${films.length} films…`);
    const filmData=await fetchCrewHybrid(films,tmdbKey,upd,signal);
    if(STATE.runId!==thisRunId) return;
    if(!filmData) throw new Error(Object.keys(FILM_DB).length>0
      ?'No films matched — try adding a free TMDB API key in ⚙ for better coverage.'
      :'No built-in database found and no TMDB API key set. Run build-db.js or add a TMDB key in ⚙.');

    if(STATE.runId!==thisRunId) return;
    upd(90,'Calculating scores…');
    const{byDir,byWriter,byActor,genres}=buildPersonMaps(films,filmData);
    // Store raw maps + filmData so settings changes can re-score without re-fetching
    STATE._filmData=filmData; STATE._films=films;
    STATE._byDir=byDir; STATE._byWriter=byWriter; STATE._byActor=byActor;
    STATE.genres=genres;
    STATE.directors=computeScores(byDir);
    STATE.writers=computeScores(byWriter);
    STATE.actors=computeScores(byActor);

    if(!STATE.directors.length&&!STATE.writers.length&&!STATE.actors.length)
      throw new Error(`Could not identify enough crew/cast data. Found ${Object.keys(byDir).length} directors, ${Object.keys(byWriter).length} writers, ${Object.keys(byActor).length} actors with ${MIN_FILMS}+ films.`);

    upd(100,''); renderResults(); showPage('page-results');
  }catch(e){
    if(STATE.runId!==thisRunId) return; // cancelled
    showError(e.message||'An unexpected error occurred.');
  }
}

function upd(pct,msg){ document.getElementById('prog-fill').style.width=pct+'%'; document.getElementById('prog-pct').textContent=pct+'%'; document.getElementById('proc-msg').textContent=msg; }
function showError(msg){ document.getElementById('err-msg').textContent=msg; showPage('page-error'); }
function cancelAnalysis(){ STATE.runId++; if(STATE.abortController){STATE.abortController.abort();STATE.abortController=null;} showPage('page-upload'); }
function resetApp(){ STATE.runId++; if(STATE.abortController){STATE.abortController.abort();STATE.abortController=null;} STATE.directors=[];STATE.writers=[];STATE.actors=[];STATE.genres=[];STATE.userName='';STATE.selectedFiles=[];STATE._byDir=null;STATE._byWriter=null;STATE._byActor=null;STATE._filmData=null;STATE._films=null; document.getElementById('file-input').value=''; document.getElementById('drop-label').textContent='Drop files here or click to browse'; switchCat('directors'); showPage('page-upload'); }

// ─── Cache Export ─────────────────────────────────────────────────────────────
function exportCache(){
  const payload={
    version:3,
    userName:STATE.userName,
    exportedAt:new Date().toISOString(),
    minFilms:MIN_FILMS,
    topActors:TOP_ACTORS,
    directors:STATE.directors,
    writers:STATE.writers,
    actors:STATE.actors,
    genres:STATE.genres||[],
    // Store raw lookup data so TOP_ACTORS slider works on reload
    filmData:STATE._filmData||null,
    films:STATE._films||null
  };
  const data=JSON.stringify(payload,null,2);
  triggerDownload((STATE.userName||'my')+'-rushmore-data.json','application/json',data);
}

// ─── SVG ──────────────────────────────────────────────────────────────────────
const NICHES=[{cx:170,cy:222,rx:73,ry:90},{cx:318,cy:192,rx:69,ry:85},{cx:468,cy:207,rx:66,ry:82},{cx:618,cy:234,rx:63,ry:78}];
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');}
function splitName(n){const p=n.split(' ');return p.length<=2?p:[p.slice(0,-1).join(' '),p[p.length-1]];}

function svgDefs(){return `<defs><linearGradient id="rSky" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#040409"/><stop offset="65%" stop-color="#0b0b1c"/><stop offset="100%" stop-color="#14142c"/></linearGradient><linearGradient id="rMtn" x1="0.25" y1="0" x2="0.75" y2="1"><stop offset="0%" stop-color="#585864"/><stop offset="45%" stop-color="#3e3e4a"/><stop offset="100%" stop-color="#1a1a22"/></linearGradient><radialGradient id="rNiche" cx="42%" cy="32%" r="68%"><stop offset="0%" stop-color="#8e8ea0"/><stop offset="55%" stop-color="#606075"/><stop offset="100%" stop-color="#3a3a4c"/></radialGradient><linearGradient id="rDist" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#22222e"/><stop offset="100%" stop-color="#18182a"/></linearGradient></defs>`;}
function svgStars(){let s='';for(let i=0;i<88;i++){const x=((i*197+43)%810)+5,y=((i*109+19)%108)+3,r=i%5===0?1.3:i%3===0?0.9:0.55,o=(0.25+(i%7)*0.08).toFixed(2);s+=`<circle cx="${x}" cy="${y}" r="${r}" fill="#fff" opacity="${o}"/>`;}return s;}
function svgMountain(H){return `<path d="M0,${H} L0,355 L70,335 L140,348 L210,318 L290,330 L375,300 L460,318 L545,295 L630,312 L720,295 L820,315 L820,${H}Z" fill="url(#rDist)" opacity="0.75"/><path d="M0,${H} L0,324 L30,310 L60,316 L88,294 L112,280 L138,288 L160,264 L180,272 L198,248 L216,257 L234,234 L252,244 L270,220 L287,228 L306,206 L322,214 L340,196 L357,204 L375,186 L392,194 L410,178 L426,185 L444,180 L462,187 L480,176 L497,184 L516,179 L534,187 L552,181 L570,192 L590,184 L610,198 L630,210 L652,224 L676,240 L700,254 L724,270 L748,284 L772,300 L798,312 L820,308 L820,${H}Z" fill="url(#rMtn)"/>`;}

function svgNiches(top4){
  let s='';
  for(let ni=0;ni<top4.length;ni++){
    const d=top4[ni],n=NICHES[ni],col=RANK_COLORS[ni],lines=splitName(d.name),lineH=18,totalH=(lines.length-1)*lineH;
    let nl='';
    for(let li=0;li<lines.length;li++){const ly=n.cy-totalH/2+li*lineH+(lines.length>1?6:9);nl+=`<text x="${n.cx}" y="${ly}" text-anchor="middle" fill="#f0e8d8" font-size="${lines.length>1?12:14}" font-family="Georgia,serif" font-weight="bold" letter-spacing="0.6">${esc(lines[li].toUpperCase())}</text>`;}
    s+=`<ellipse cx="${n.cx}" cy="${n.cy}" rx="${n.rx+11}" ry="${n.ry+11}" fill="#06060d" opacity="0.85"/><ellipse cx="${n.cx}" cy="${n.cy}" rx="${n.rx+5}" ry="${n.ry+5}" fill="#282834"/><ellipse cx="${n.cx}" cy="${n.cy}" rx="${n.rx}" ry="${n.ry}" fill="url(#rNiche)"/><ellipse cx="${n.cx-10}" cy="${n.cy-n.ry*0.38}" rx="${n.rx*0.55}" ry="${n.ry*0.22}" fill="#c8c8dc" opacity="0.09"/><text x="${n.cx}" y="${n.cy-n.ry+23}" text-anchor="middle" fill="${col}" font-size="10" font-family="Georgia,serif" letter-spacing="3" font-weight="bold">#${ni+1}</text><line x1="${n.cx-20}" y1="${n.cy-n.ry+30}" x2="${n.cx+20}" y2="${n.cy-n.ry+30}" stroke="${col}" stroke-width="0.7" opacity="0.35"/>${nl}<text x="${n.cx}" y="${n.cy+n.ry-14}" text-anchor="middle" fill="${col}" font-size="9" font-family="Georgia,serif" opacity="0.75" letter-spacing="1">${(d.score*100).toFixed(1)}</text>`;
  }
  return s;
}

function svgCards(top4,MTN_H,CARD_H){
  const W=820,colW=W/4;
  let s=`<rect x="0" y="${MTN_H}" width="${W}" height="${CARD_H}" fill="#0a0a14"/><line x1="0" y1="${MTN_H}" x2="${W}" y2="${MTN_H}" stroke="#1e1e30" stroke-width="1"/>`;
  for(let ci=0;ci<top4.length;ci++){
    const cd=top4[ci],cc=RANK_COLORS[ci],cx0=ci*colW,cy0=MTN_H,cp=18;
    if(ci>0)s+=`<line x1="${cx0}" y1="${cy0+10}" x2="${cx0}" y2="${cy0+CARD_H-10}" stroke="#1e1e30" stroke-width="1"/>`;
    s+=`<rect x="${cx0+cp}" y="${cy0+cp}" width="28" height="28" rx="6" fill="${cc}18"/><text x="${cx0+cp+14}" y="${cy0+cp+19}" text-anchor="middle" fill="${cc}" font-size="13" font-family="Georgia,serif" font-weight="bold">${ci+1}</text>`;
    const dl=splitName(cd.name);for(let li=0;li<dl.length;li++)s+=`<text x="${cx0+cp+36}" y="${cy0+cp+15+li*15}" fill="#f0e8d8" font-size="11" font-family="Georgia,serif" font-weight="bold">${esc(dl[li])}</text>`;
    s+=`<text x="${cx0+cp}" y="${cy0+82}" fill="#55556a" font-size="10" font-family="Georgia,serif">${cd.filmCount} film${cd.filmCount!==1?'s':''}${cd.rewatchCount>0?' · '+cd.rewatchCount+' rw':''}</text>`;
    s+=`<text x="${cx0+cp}" y="${cy0+102}" fill="#44445a" font-size="8" font-family="Georgia,serif" letter-spacing="1.5">AVG RATING</text>`;
    for(let pi=0;pi<10;pi++)s+=`<rect x="${cx0+cp+pi*13}" y="${cy0+107}" width="10" height="3" rx="1.5" fill="${(pi/10)*5<cd.avgRating?cc:'#1e1e2e'}"/>`;
    s+=`<text x="${cx0+cp+135}" y="${cy0+111}" fill="#777" font-size="9" font-family="Georgia,serif">${cd.avgRating.toFixed(2)}</text>`;
    s+=`<text x="${cx0+cp}" y="${cy0+128}" fill="#44445a" font-size="8" font-family="Georgia,serif" letter-spacing="1.5">TOP 3 AVG</text>`;
    for(let ti=0;ti<10;ti++)s+=`<rect x="${cx0+cp+ti*13}" y="${cy0+133}" width="10" height="3" rx="1.5" fill="${(ti/10)*5<cd.top3Avg?cc:'#1e1e2e'}"/>`;
    s+=`<text x="${cx0+cp+135}" y="${cy0+137}" fill="#777" font-size="9" font-family="Georgia,serif">${cd.top3Avg.toFixed(2)}</text>`;
    s+=`<text x="${cx0+cp}" y="${cy0+156}" fill="#44445a" font-size="8" font-family="Georgia,serif" letter-spacing="1.5">BEST FILMS</text>`;
    for(let fi=0;fi<cd.topFilms.length;fi++){const tf=cd.topFilms[fi],fy=cy0+168+fi*20,tr=tf.name.length>22?tf.name.slice(0,21)+'…':tf.name,fs='★'.repeat(Math.floor(tf.rating))+(tf.rating%1>=0.5?'½':'');s+=`<text x="${cx0+cp}" y="${fy}" fill="#c8c0ae" font-size="10" font-family="Georgia,serif">${esc(tr)}</text><text x="${cx0+colW-cp}" y="${fy}" text-anchor="end" fill="${cc}" font-size="10" font-family="Georgia,serif">${fs}</text>`;}
    s+=`<line x1="${cx0+cp}" y1="${cy0+CARD_H-42}" x2="${cx0+colW-cp}" y2="${cy0+CARD_H-42}" stroke="${cc}22" stroke-width="1"/><text x="${cx0+cp}" y="${cy0+CARD_H-23}" fill="#44445a" font-size="8" font-family="Georgia,serif" letter-spacing="2">SCORE</text><text x="${cx0+colW-cp}" y="${cy0+CARD_H-18}" text-anchor="end" fill="${cc}" font-size="22" font-family="Georgia,serif" font-weight="bold">${(cd.score*100).toFixed(1)}</text>`;
  }
  return s;
}

function buildInlineSVG(top4,label){
  const W=820,H=440;
  return `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" style="width:100%;display:block;border-radius:12px 12px 0 0">${svgDefs()}<rect width="${W}" height="${H}" fill="url(#rSky)"/>${svgStars()}${svgMountain(H)}${svgNiches(top4)}<text x="410" y="${H-14}" text-anchor="middle" fill="#c8a84050" font-size="10" font-family="Georgia,serif" letter-spacing="5">${esc(label.toUpperCase())}</text></svg>`;
}

function buildExportSVG(top4,label){
  const W=820,MTN_H=440,CARD_H=270,H=MTN_H+CARD_H;
  return `<?xml version="1.0" encoding="UTF-8"?><svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" xmlns="http://www.w3.org/2000/svg">${svgDefs()}<rect width="${W}" height="${MTN_H}" fill="url(#rSky)"/>${svgStars()}${svgMountain(MTN_H)}${svgNiches(top4)}<text x="410" y="${MTN_H-14}" text-anchor="middle" fill="#c8a84050" font-size="10" font-family="Georgia,serif" letter-spacing="5">${esc(label.toUpperCase())}</text>${svgCards(top4,MTN_H,CARD_H)}<text x="${W/2}" y="${MTN_H+CARD_H-10}" text-anchor="middle" fill="#c8a84025" font-size="9" font-family="Georgia,serif" letter-spacing="5">${esc(label.toUpperCase())}</text></svg>`;
}

// ─── PNG Download ─────────────────────────────────────────────────────────────
function downloadPNG(){
  const cat=STATE.currentCat, top4=STATE[cat].slice(0,4);
  if(!top4.length){alert('No data for '+CAT_LABELS[cat]+' yet.');return;}
  const un=STATE.userName, label=`${un?un+"'s ":''}${CAT_LABELS[cat]} Mount Rushmore`;
  const svgStr=buildExportSVG(top4,label);
  const W=820,H=710,SCALE=2;
  const canvas=document.createElement('canvas'); canvas.width=W*SCALE; canvas.height=H*SCALE;
  const ctx=canvas.getContext('2d'); ctx.scale(SCALE,SCALE);
  const blob=new Blob([svgStr],{type:'image/svg+xml;charset=utf-8'}), url=URL.createObjectURL(blob);
  const img=new Image();
  img.onload=function(){ctx.drawImage(img,0,0,W,H);URL.revokeObjectURL(url);canvas.toBlob(function(pb){if(!pb){triggerDownload((un||'my')+'-'+cat+'-rushmore.svg','image/svg+xml',svgStr);return;}const a=document.createElement('a');a.download=(un||'my')+'-'+cat+'-mount-rushmore.png';a.href=URL.createObjectURL(pb);a.click();},'image/png');};
  img.onerror=function(){URL.revokeObjectURL(url);triggerDownload((un||'my')+'-'+cat+'-rushmore.svg','image/svg+xml',svgStr);};
  img.src=url;
}

function triggerDownload(filename,mime,data){const a=document.createElement('a');a.download=filename;a.href='data:'+mime+';charset=utf-8,'+encodeURIComponent(data);a.click();}

// ─── Person Card HTML ─────────────────────────────────────────────────────────
function pipsHTML(val,col){let h='<div style="display:flex;gap:2px;align-items:center">';for(let i=0;i<10;i++)h+=`<div style="width:11px;height:3px;border-radius:2px;background:${(i/10)*5<val?col:'#1e1e2e'}"></div>`;h+=`<span style="color:#888;font-size:11px;margin-left:5px">${val?val.toFixed(2):'—'}</span></div>`;return h;}

function personCardHTML(d,rank){
  const ac=rank<=4?RANK_COLORS[rank-1]:'#557799';
  const stars=r=>'★'.repeat(Math.floor(r))+(r%1>=0.5?'½':'');
  let topFilms='';
  for(const f of d.topFilms)topFilms+=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px"><span style="color:#c8c0ae;font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">${esc(f.name)}</span><span style="color:${ac};font-size:10px;margin-left:8px;flex-shrink:0">${stars(f.rating)}</span></div>`;
  return `<div class="card" style="border:1px solid ${ac}28">
    <div style="position:absolute;top:0;left:10%;right:10%;height:2px;background:linear-gradient(90deg,transparent,${ac}aa,transparent)"></div>
    <div style="display:flex;gap:12px;align-items:flex-start;margin-bottom:14px">
      <div style="width:34px;height:34px;border-radius:8px;background:${ac}18;border:1px solid ${ac}44;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:${ac};font-size:13px;font-weight:bold">${rank}</div>
      <div style="min-width:0;flex:1"><div style="color:#f0e8d8;font-size:14px;font-weight:bold;line-height:1.3">${esc(d.name)}</div>
        <div style="color:#66667a;font-size:11px;margin-top:2px">${d.filmCount} film${d.filmCount!==1?'s':''}${d.rewatchCount>0?' · '+d.rewatchCount+' rewatch'+(d.rewatchCount!==1?'es':''):''}</div></div>
      <div style="color:${ac};font-size:18px;font-weight:bold;flex-shrink:0">${(d.score*100).toFixed(1)}</div>
    </div>
    <div style="margin-bottom:12px">
      <div style="color:#44445a;font-size:8px;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px">Avg Rating</div>${pipsHTML(d.avgRating,ac)}
      <div style="color:#44445a;font-size:8px;letter-spacing:2px;text-transform:uppercase;margin:8px 0 4px">Top 3 Avg</div>${pipsHTML(d.top3Avg,ac)}
    </div>
    ${d.topFilms.length?`<div><div style="color:#44445a;font-size:8px;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px">Best Films</div>${topFilms}</div>`:''}
  </div>`;
}

// ─── Render Category Panel ────────────────────────────────────────────────────
function renderCategoryPanel(cat){
  const data=STATE[cat], top4=data.slice(0,4), un=STATE.userName;
  const catLabel=CAT_LABELS[cat], icon=CAT_ICONS[cat];
  const rushLabel=`${un?un+"'s ":'Your '}${catLabel} Mount Rushmore`;
  const rankMap={}; data.forEach((d,i)=>rankMap[d.name]=i+1);

  if(!data.length){
    return `<div style="text-align:center;padding:80px 0;color:#33334a">
      <div style="font-size:32px;margin-bottom:12px">${icon}</div>
      <div style="font-size:15px">Not enough ${catLabel.toLowerCase()} with ${MIN_FILMS}+ films in your library.</div>
    </div>`;
  }

  // Search/sort state per category (stored on window for simplicity)
  const searchId=`search-${cat}`, sortId=`sort-${cat}`;

  const top4CardsHTML=top4.map((d,i)=>personCardHTML(d,i+1)).join('');
  const alsoHTML=data.slice(4,14).map((d,i)=>`<div class="also-chip"><span style="color:#33334a;font-size:11px">#${i+5}</span><span style="color:#b8b0a0;font-size:13px">${esc(d.name)}</span><span style="color:#c8a84077;font-size:11px">${(d.score*100).toFixed(1)}</span></div>`).join('');

  return `
    <div style="margin-bottom:16px">
      <div class="eyebrow" style="margin-bottom:5px">${icon} ${catLabel}</div>
      <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:22px;color:#f0e8d8;font-weight:700">${esc(rushLabel)}</h1>
    </div>
    <div id="svg-${cat}">${buildInlineSVG(top4,rushLabel)}</div>
    <div style="background:#0d0d1c;border:1px solid #1c1c2c;border-top:none;border-radius:0 0 12px 12px;padding:10px 20px;display:flex;gap:20px;flex-wrap:wrap;margin-bottom:22px">
      <div style="font-size:11px"><span style="color:#77778a">Avg Rating</span><span style="color:#c8a84077;margin-left:5px">${Math.round(WEIGHTS.avgRating*100)}%</span></div>
      <div style="font-size:11px"><span style="color:#77778a">Films Seen</span><span style="color:#c8a84077;margin-left:5px">${Math.round(WEIGHTS.filmCount*100)}%</span></div>
      <div style="font-size:11px"><span style="color:#77778a">Top 3 Avg</span><span style="color:#c8a84077;margin-left:5px">${Math.round(WEIGHTS.top3Score*100)}%</span></div>
      <div style="font-size:11px"><span style="color:#77778a">Rewatches</span><span style="color:#c8a84077;margin-left:5px">${Math.round(WEIGHTS.rewatches*100)}%</span></div>
      <div style="font-size:11px"><span style="color:#77778a">Min films</span><span style="color:#c8a84077;margin-left:5px">${MIN_FILMS}</span></div>
    </div>
    <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:32px">${top4CardsHTML}</div>
    ${data.length>4?`<div style="margin-bottom:32px"><div class="eyebrow" style="margin-bottom:12px">Also Considered</div><div style="display:flex;flex-wrap:wrap;gap:10px">${alsoHTML}</div></div>`:''}
    <hr class="section-divider"/>
    <div style="margin-bottom:16px">
      <div class="eyebrow" style="margin-bottom:8px">All ${catLabel} (${data.length})</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <input id="${searchId}" class="input-field" style="flex:1;min-width:180px" placeholder="Search ${catLabel.toLowerCase()}…" oninput="filterCat('${cat}')"/>
        <select id="${sortId}" class="input-field" style="width:auto;cursor:pointer;background:#0e0e1c;border-color:#252535;color:#88889a" onchange="filterCat('${cat}')">
          <option value="score">Sort: Score</option><option value="films">Sort: Films Seen</option><option value="rating">Sort: Avg Rating</option><option value="rewatches">Sort: Rewatches</option><option value="name">Sort: Name A–Z</option>
        </select>
      </div>
    </div>
    <div id="grid-${cat}" class="dir-grid"></div>
    <div id="empty-${cat}" style="text-align:center;color:#33334a;padding:40px 0;font-size:14px;display:none">No results match your search.</div>
  `;
}

function filterCat(cat){
  const search=(document.getElementById(`search-${cat}`).value||'').toLowerCase();
  const sort=(document.getElementById(`sort-${cat}`).value)||'score';
  const rankMap={}; STATE[cat].forEach((d,i)=>rankMap[d.name]=i+1);
  let data=[...STATE[cat]].filter(d=>!search||d.name.toLowerCase().includes(search));
  data.sort((a,b)=>sort==='name'?a.name.localeCompare(b.name):sort==='films'?b.filmCount-a.filmCount:sort==='rating'?b.avgRating-a.avgRating:sort==='rewatches'?b.rewatchCount-a.rewatchCount:b.score-a.score);
  const grid=document.getElementById(`grid-${cat}`), empty=document.getElementById(`empty-${cat}`);
  if(!data.length){grid.innerHTML='';empty.style.display='block';}
  else{empty.style.display='none';grid.innerHTML=data.map(d=>personCardHTML(d,rankMap[d.name])).join('');}
}

// ─── Render Results ───────────────────────────────────────────────────────────
function renderResults(){
  const un=STATE.userName;
  document.getElementById('nav-title').textContent=(un?un+"'s":'My')+' Mount Rushmore';
  ['directors','writers','actors'].forEach(cat=>{
    document.getElementById('cat-'+cat).innerHTML=renderCategoryPanel(cat);
    if(STATE[cat].length) filterCat(cat);
  });
  renderGenreStrip();
  // Data quality banners
  const films=STATE._films||[];
  const anyRated=films.some(f=>f.rating>0);
  const anyRewatch=films.some(f=>f.rewatchCount>0);
  const banners=[];
  if(films.length&&!anyRated) banners.push('No star ratings detected — scores are based on view count only. Upload <b>ratings.csv</b> alongside your diary for full scoring.');
  if(films.length&&!anyRewatch) banners.push('No diary rewatch data detected — the rewatch weight has no effect. Upload <b>diary.csv</b> for rewatch scoring.');
  if(STATE._dbMisses>0&&!getKey('tmdb')) banners.push(STATE._dbMisses+' film'+(STATE._dbMisses===1?'':'s')+' not found in the built-in database and were skipped. Add a free <b>TMDB API key</b> in ⚙ to look them up live.');
  const el=document.getElementById('data-quality-banner');
  el.innerHTML=banners.map(b=>`<div style="background:#1a1410;border-left:3px solid #c8a840;padding:10px 20px;font-size:12px;color:#998870">${b}</div>`).join('');
}

function renderGenreStrip(){
  const genres=STATE.genres||[];
  const strip=document.getElementById('genre-strip');
  if(!genres.length){strip.style.display='none';return;}
  strip.style.display='';
  const top=genres.slice(0,8);
  document.getElementById('genre-chips').innerHTML=top.map(g=>`
    <div style="display:flex;align-items:center;gap:6px;background:#111120;border:1px solid #1e1e2e;border-radius:20px;padding:4px 12px">
      <span style="color:#c8c0b0;font-size:12px">${esc(String(g.genre))}</span>
      <span style="color:#c8a84077;font-size:10px">${esc(String(g.count))}</span>
    </div>`).join('');
}

function switchCat(cat){
  STATE.currentCat=cat;
  ['directors','writers','actors'].forEach(c=>{
    document.getElementById('cat-'+c).style.display=c===cat?'':'none';
    document.getElementById('tab-btn-'+c).classList.toggle('active',c===cat);
  });
}

// ─── Name input reactive label ────────────────────────────────────────────────
document.getElementById('name-input').addEventListener('input',function(){
  const v=this.value.trim();
  document.getElementById('analyze-btn').textContent=v?`Let's go, ${v} →`:'Analyze →';
});

// ─── Weight Sliders ───────────────────────────────────────────────────────────
let weightsOpen = false;
function toggleWeights(){
  weightsOpen=!weightsOpen;
  document.getElementById('weights-panel').style.display=weightsOpen?'block':'none';
}

function onSlider(key, val){
  WEIGHTS[key]=parseInt(val)/100;
  document.getElementById('lbl-'+key).textContent=val+'%';
  const total=Math.round((WEIGHTS.avgRating+WEIGHTS.filmCount+WEIGHTS.top3Score+WEIGHTS.rewatches)*100);
  const badge=document.getElementById('weights-total-badge');
  badge.textContent='Total: '+total+'%';
  badge.style.color=total===100?'#4a9a4a':'#c05050';
  // Re-score and re-render if we have data
  if(STATE.directors.length||STATE.writers.length||STATE.actors.length){
    scheduleRender();
  }
}

function resetWeights(){
  const defaults={avgRating:45,filmCount:40,top3Score:7,rewatches:8};
  for(const [k,v] of Object.entries(defaults)){
    WEIGHTS[k]=v/100;
    document.getElementById('sl-'+k).value=v;
    document.getElementById('lbl-'+k).textContent=v+'%';
  }
  document.getElementById('weights-total-badge').textContent='Total: 100%';
  document.getElementById('weights-total-badge').style.color='#4a9a4a';
  if(STATE.directors.length||STATE.writers.length||STATE.actors.length) reScoreAndRender();
}

let _renderTimer;
function scheduleRender(){ clearTimeout(_renderTimer); _renderTimer=setTimeout(reScoreAndRender,60); }

// Re-run scoring (and optionally map-building) without re-fetching
function reScoreAndRender(){
  if(!STATE._byDir) return;
  // If we have raw filmData, re-run buildPersonMaps so TOP_ACTORS changes take effect
  if(STATE._filmData && STATE._films){
    const{byDir,byWriter,byActor,genres}=buildPersonMaps(STATE._films,STATE._filmData);
    STATE._byDir=byDir; STATE._byWriter=byWriter; STATE._byActor=byActor; STATE.genres=genres;
  }
  STATE.directors=computeScores(STATE._byDir);
  STATE.writers=computeScores(STATE._byWriter);
  STATE.actors=computeScores(STATE._byActor);
  renderResults();
}

function onSettingSlider(key, val){
  const v=parseInt(val);
  document.getElementById('lbl-'+key).textContent=v;
  if(key==='minFilms') MIN_FILMS=v;
  if(key==='topActors') TOP_ACTORS=v;
  updateModalText();
  if(key==='topActors' && !STATE._filmData){
    // Loaded from a v1/v2 cache — actors slider can't re-rank without raw data
    showToast('Re-export your data to enable the actors slider');
    return;
  }
  if(STATE.directors.length||STATE.writers.length||STATE.actors.length) scheduleRender();
}

function openModal(){
  updateModalText();
  document.getElementById('how-modal').classList.add('open');
}
function closeModal(){ document.getElementById('how-modal').classList.remove('open'); }

function updateModalText(){
  const fmt=v=>(v*100).toFixed(0)+'%';
  ['avgRating','filmCount','top3Score','rewatches'].forEach(k=>{
    const el=document.getElementById('modal-w-'+k); if(el) el.textContent=fmt(WEIGHTS[k]);
  });
  const mf=document.getElementById('modal-min-films'); if(mf) mf.textContent=MIN_FILMS;
  const ta=document.getElementById('modal-top-actors'); if(ta) ta.textContent=TOP_ACTORS;
}

// ─── Share / URL encoding ─────────────────────────────────────────────────────

// Strips the heavy 'films' array from scored entries — keeps only display fields
function slimScored(arr){
  return (arr||[]).slice(0,20).map(d=>({
    name:d.name, filmCount:d.filmCount, rewatchCount:d.rewatchCount,
    avgRating:d.avgRating, top3Avg:d.top3Avg, score:d.score,
    topFilms:(d.topFilms||[]).map(f=>({name:f.name,year:f.year,rating:f.rating}))
  }));
}

function generateShareURL(){
  const payload={
    v:2,
    un:STATE.userName||'',
    genres:(STATE.genres||[]).slice(0,10),
    d:slimScored(STATE.directors),
    w:slimScored(STATE.writers),
    a:slimScored(STATE.actors)
  };
  const json=JSON.stringify(payload);
  const bytes=new TextEncoder().encode(json);
  let bin=''; for(const b of bytes) bin+=String.fromCharCode(b);
  const encoded=btoa(bin);
  return window.location.href.split('#')[0]+'#share='+encoded;
}

function shareResults(){
  try{
    const url=generateShareURL();
    navigator.clipboard.writeText(url).then(()=>showToast('Link copied!'))
      .catch(()=>{ prompt('Copy this link:', url); });
  } catch(e){ showError('Could not generate share link: '+e.message); }
}

function showToast(msg){
  const t=document.getElementById('share-toast');
  t.textContent=msg; t.style.display='block';
  setTimeout(()=>t.style.display='none', 2200);
}

// Validate and sanitize a decoded share payload
function validateShare(p){
  if(!p||typeof p!=='object') throw new Error('bad payload');
  const cleanPerson=d=>({
    name:String(d?.name??''),
    filmCount:Number(d?.filmCount)||0,
    rewatchCount:Number(d?.rewatchCount)||0,
    avgRating:Number(d?.avgRating)||0,
    top3Avg:Number(d?.top3Avg)||0,
    score:Number(d?.score)||0,
    topFilms:Array.isArray(d?.topFilms)?d.topFilms.slice(0,5).map(f=>({
      name:String(f?.name??''),year:Number(f?.year)||0,rating:Number(f?.rating)||0
    })):[]
  });
  return{
    userName:String(p.un||'').slice(0,60),
    directors:Array.isArray(p.d)?p.d.slice(0,50).map(cleanPerson):[],
    writers:Array.isArray(p.w)?p.w.slice(0,50).map(cleanPerson):[],
    actors:Array.isArray(p.a)?p.a.slice(0,50).map(cleanPerson):[],
    genres:Array.isArray(p.genres)?p.genres.slice(0,20).map(g=>({
      genre:String(g?.genre??''),count:Number(g?.count)||0
    })):[]
  };
}

// Load and render a share view from URL hash
function loadShareFromHash(){
  const hash=window.location.hash;
  if(!hash.startsWith('#share=')) return false;
  try{
    const encoded=hash.slice('#share='.length);
    const bin=atob(encoded);
    const bytes=Uint8Array.from(bin,c=>c.charCodeAt(0));
    const json=new TextDecoder().decode(bytes);
    const p=JSON.parse(json);
    const shareState=validateShare(p);
    renderShareView(shareState);
    showPage('page-share');
    return true;
  } catch(e){
    console.warn('Failed to load share data from URL:', e);
    showPage('page-upload');
    setTimeout(()=>showToast('Could not load share link — it may be corrupted or outdated.'), 300);
    return false;
  }
}

function renderShareView(shareState){
  const un=shareState.userName;
  document.getElementById('share-nav-title').textContent=(un?un+"'s":'Cinematic')+' Mount Rushmore';
  document.title=(un?un+"'s ":'')+'Cinematic Mount Rushmore';

  // Genre strip
  const genres=shareState.genres||[];
  const genreStrip=document.getElementById('share-genre-strip');
  if(genres.length){
    genreStrip.style.display='';
    document.getElementById('share-genre-chips').innerHTML=genres.map(g=>
      `<div style="display:flex;align-items:center;gap:6px;background:#111120;border:1px solid #1e1e2e;border-radius:20px;padding:4px 12px"><span style="color:#c8c0b0;font-size:12px">${esc(String(g.genre))}</span><span style="color:#c8a84077;font-size:10px">${esc(String(g.count))}</span></div>`
    ).join('');
  } else { genreStrip.style.display='none'; }

  ['directors','writers','actors'].forEach(cat=>{
    const data=shareState[cat]||[];
    const el=document.getElementById('share-cat-'+cat);
    el.innerHTML=renderShareCatPanel(data, cat, shareState.userName);
  });
}

function renderShareCatPanel(data, cat, userName){
  const catLabel=CAT_LABELS[cat], icon=CAT_ICONS[cat];
  const top4=data.slice(0,4);
  const rushLabel=`${userName?userName+"'s ":''}${catLabel} Mount Rushmore`;

  if(!top4.length) return `<div style="text-align:center;padding:60px 0;color:#33334a"><div style="font-size:32px;margin-bottom:10px">${icon}</div><div>No ${catLabel.toLowerCase()} data in this share.</div></div>`;

  const rankMap={}; data.forEach((d,i)=>rankMap[d.name]=i+1);
  const alsoHTML=data.slice(4,12).map((d,i)=>
    `<div class="also-chip"><span style="color:#33334a;font-size:11px">#${i+5}</span><span style="color:#b8b0a0;font-size:13px">${esc(d.name)}</span><span style="color:#c8a84077;font-size:11px">${(d.score*100).toFixed(1)}</span></div>`
  ).join('');

  // Share banner with copy button
  const shareUrl=window.location.href;
  const banner=`<div class="share-banner">
    <div>
      <div style="color:#f0e8d8;font-size:15px;font-weight:bold;margin-bottom:4px">${esc(rushLabel)}</div>
      <div style="color:#55556a;font-size:12px">Scored from Letterboxd data · ${data.length} ${catLabel.toLowerCase()} with 3+ films</div>
    </div>
    <button class="share-copy-btn" onclick="navigator.clipboard.writeText(window.location.href).then(()=>showToast('Link copied!')).catch(()=>prompt('Copy this link:',window.location.href))">🔗 Copy Link</button>
  </div>`;

  return `${banner}
    <div id="share-svg-${cat}">${buildInlineSVG(top4, rushLabel)}</div>
    <div style="background:#0d0d1c;border:1px solid #1c1c2c;border-top:none;border-radius:0 0 12px 12px;padding:10px 20px;margin-bottom:22px;color:#55556a;font-size:11px">
      Scores reflect viewing history &amp; ratings from Letterboxd.
    </div>
    <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:32px">${top4.map((d,i)=>personCardHTML(d,i+1)).join('')}</div>
    ${data.length>4?`<div style="margin-bottom:32px"><div class="eyebrow" style="margin-bottom:12px">Also Considered</div><div style="display:flex;flex-wrap:wrap;gap:10px">${alsoHTML}</div></div>`:''}
    ${data.length>4?`<hr class="section-divider"/><div style="margin-bottom:14px"><div class="eyebrow" style="margin-bottom:10px">All ${catLabel}</div></div><div class="dir-grid">${data.map(d=>personCardHTML(d,rankMap[d.name])).join('')}</div>`:''}
  `;
}

function switchShareCat(cat){
  ['directors','writers','actors'].forEach(c=>{
    document.getElementById('share-cat-'+c).style.display=c===cat?'':'none';
    document.getElementById('share-tab-btn-'+c).classList.toggle('active',c===cat);
  });
}

// ─── Init ─────────────────────────────────────────────────────────────────────
updateConfigBadge();
// Check for shared URL on load
if(!loadShareFromHash()){
  showPage('page-upload');
}
// Also handle back/forward navigation
window.addEventListener('hashchange', ()=>{ if(window.location.hash.startsWith('#share=')) loadShareFromHash(); });
</script>

<!-- ══════════════════════════════════ HOW IT WORKS MODAL -->
<div id="how-modal" class="modal-bg" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="eyebrow" style="margin-bottom:10px">About</div>
    <h2 style="font-family:'Playfair Display',Georgia,serif;font-size:22px;color:#f0e8d8;font-weight:700;margin-bottom:18px">How It Works</h2>

    <div style="color:#88889a;font-size:13px;line-height:1.8;margin-bottom:20px">
      Your Mount Rushmore is the four directors, writers, and actors who show up most meaningfully across your Letterboxd history — not just by volume, but by how much you love their work.
    </div>

    <div style="margin-bottom:18px">
      <div style="color:#c8c0b0;font-size:13px;font-weight:bold;margin-bottom:10px">The Scoring Formula</div>
      <div style="display:flex;flex-direction:column;gap:8px">
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#141422;border-radius:8px">
          <div><div style="color:#e0d8c8;font-size:13px">⭐ Avg Rating</div><div style="color:#55556a;font-size:11px">Your mean star rating across all their films you've seen</div></div>
          <div id="modal-w-avgRating" style="color:#c8a840;font-size:15px;font-weight:bold;flex-shrink:0;margin-left:12px">45%</div>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#141422;border-radius:8px">
          <div><div style="color:#e0d8c8;font-size:13px">🎬 Films Seen</div><div style="color:#55556a;font-size:11px">How many of their films are in your diary — normalized against the most-seen director</div></div>
          <div id="modal-w-filmCount" style="color:#c8a840;font-size:15px;font-weight:bold;flex-shrink:0;margin-left:12px">40%</div>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#141422;border-radius:8px">
          <div><div style="color:#e0d8c8;font-size:13px">🏆 Top 3 Avg</div><div style="color:#55556a;font-size:11px">Average of your three highest-rated films from them — rewards consistent excellence</div></div>
          <div id="modal-w-top3Score" style="color:#c8a840;font-size:15px;font-weight:bold;flex-shrink:0;margin-left:12px">7%</div>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#141422;border-radius:8px">
          <div><div style="color:#e0d8c8;font-size:13px">🔁 Rewatches</div><div style="color:#55556a;font-size:11px">Films you've logged more than once — a strong signal of genuine love</div></div>
          <div id="modal-w-rewatches" style="color:#c8a840;font-size:15px;font-weight:bold;flex-shrink:0;margin-left:12px">8%</div>
        </div>
      </div>
      <div style="color:#44445a;font-size:11px;margin-top:10px;line-height:1.6">Weights are normalized so the relative ratios always matter, even if they don't sum to 100%. Adjust them with the ⚖ Settings button. Minimum <span id="modal-min-films">3</span> films required to qualify.</div>
    </div>

    <div style="margin-bottom:18px">
      <div style="color:#c8c0b0;font-size:13px;font-weight:bold;margin-bottom:8px">Your Data</div>
      <div style="color:#88889a;font-size:13px;line-height:1.8">Your Letterboxd export is processed entirely in your browser. Nothing is sent to any server except the TMDB API for director/writer/actor lookups. Your API key is stored only in your browser's localStorage and never leaves your device.</div>
    </div>

    <div>
      <div style="color:#c8c0b0;font-size:13px;font-weight:bold;margin-bottom:8px">Writers &amp; Actors</div>
      <div style="color:#88889a;font-size:13px;line-height:1.8">Writers are credited for Screenplay, Story, and Adaptation roles. Actors are the top <span id="modal-top-actors">5</span> billed cast members per film. Both use the same scoring formula as directors.</div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════ PAGE: SHARE VIEW -->
<div id="page-share" class="page">
  <!-- Minimal nav for share view -->
  <div class="nav">
    <div class="nav-inner">
      <div style="color:#c8a840;font-size:13px;font-weight:bold;letter-spacing:.5px;flex-shrink:0" id="share-nav-title">Cinematic Mount Rushmore</div>
      <div style="display:flex;gap:2px">
        <button class="nav-tab active" id="share-tab-btn-directors" onclick="switchShareCat('directors')">🎬 Directors</button>
        <button class="nav-tab" id="share-tab-btn-writers" onclick="switchShareCat('writers')">✍️ Writers</button>
        <button class="nav-tab" id="share-tab-btn-actors" onclick="switchShareCat('actors')">🎭 Actors</button>
      </div>
      <div style="flex:1"></div>
      <button class="btn-gold btn-sm" onclick="showPage('page-upload')" style="flex-shrink:0">Make Your Own →</button>
    </div>
  </div>

  <!-- Genre strip for share view -->
  <div id="share-genre-strip" style="display:none;background:#080810;border-bottom:1px solid #111120;padding:14px 0">
    <div class="wrap">
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <span style="color:#44445a;font-size:10px;letter-spacing:3px;text-transform:uppercase;flex-shrink:0">Top Genres</span>
        <div id="share-genre-chips" style="display:flex;gap:8px;flex-wrap:wrap"></div>
      </div>
    </div>
  </div>

  <!-- Category panels -->
  <div id="share-cat-directors" class="wrap" style="padding-top:28px;padding-bottom:60px"></div>
  <div id="share-cat-writers"   class="wrap" style="padding-top:28px;padding-bottom:60px;display:none"></div>
  <div id="share-cat-actors"    class="wrap" style="padding-top:28px;padding-bottom:60px;display:none"></div>

  <!-- CTA footer -->
  <div style="background:#06060f;border-top:1px solid #151525;padding:40px 20px;text-align:center">
    <div style="color:#44445a;font-size:10px;letter-spacing:5px;text-transform:uppercase;margin-bottom:12px">Built with</div>
    <div style="font-family:'Playfair Display',Georgia,serif;font-size:26px;color:#f0e8d8;font-weight:700;margin-bottom:6px">Cinematic Mount Rushmore</div>
    <div style="color:#55556a;font-size:14px;margin-bottom:24px">Find the directors, writers &amp; actors who define your taste — scored from your Letterboxd data.</div>
    <button class="btn-gold" onclick="showPage('page-upload')" style="font-size:16px;padding:14px 32px">Make Your Own →</button>
  </div>
</div>

<!-- Share toast -->
<div id="share-toast" style="display:none;position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:#c8a840;color:#08080f;padding:10px 22px;border-radius:100px;font-size:13px;font-weight:bold;z-index:9999;pointer-events:none">Link copied!</div>
</body>
</html>
