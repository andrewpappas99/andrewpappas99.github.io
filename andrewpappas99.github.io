<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src https://api.themoviedb.org https://image.tmdb.org; script-src 'self' 'unsafe-inline'; base-uri 'none'; form-action 'none'">
<title>Cinematic Mount Rushmore</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#08080f;color:#e0d8c8;font-family:Georgia,'Times New Roman',serif;min-height:100vh}
input,select,button{font-family:inherit}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:#0e0e1c}::-webkit-scrollbar-thumb{background:#2a2a42;border-radius:3px}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.spinner{width:52px;height:52px;border:3px solid #181828;border-top-color:#c8a840;border-radius:50%;animation:spin .85s linear infinite;margin:0 auto 26px}
.page{display:none}.page.active{display:block}
.wrap{max-width:980px;margin:0 auto;padding:0 20px}
.eyebrow{color:#c8a840;font-size:10px;letter-spacing:6px;text-transform:uppercase;margin-bottom:10px}
.btn-gold{background:#c8a840;color:#08080f;border:none;border-radius:9px;padding:13px 22px;font-size:15px;font-weight:bold;cursor:pointer;transition:opacity .15s}
.btn-gold:hover{opacity:.88}
.btn-ghost{background:transparent;border:1px solid #252535;color:#66667a;border-radius:9px;padding:11px 18px;cursor:pointer;font-size:13px;transition:border-color .15s}
.btn-ghost:hover{border-color:#3a3a52;color:#88889a}
.btn-sm{padding:7px 14px;font-size:12px;border-radius:7px}
.input-field{background:#111120;border:1px solid #222238;color:#e0d8c8;border-radius:8px;padding:12px 16px;font-size:14px;outline:none;transition:border-color .15s;width:100%}
.input-field:focus{border-color:#c8a84066}
.card{background:linear-gradient(150deg,#141420,#0e0e18);border-radius:10px;padding:18px 20px;position:relative;overflow:hidden}
.progress-bar{background:#0e0e1c;border-radius:100px;height:4px;overflow:hidden}
.progress-fill{background:linear-gradient(90deg,#6a5010,#c8a840);height:100%;border-radius:100px;transition:width .3s ease}
.drop-zone{border:2px dashed #252535;border-radius:14px;padding:40px 20px;text-align:center;cursor:pointer;background:#0c0c1a;transition:border-color .2s,background .2s}
.drop-zone:hover,.drop-zone.drag{border-color:#c8a840;background:#c8a8400d}
.nav{background:#06060f;border-bottom:1px solid #151525;position:sticky;top:0;z-index:100}
.nav-inner{display:flex;align-items:center;gap:10px;height:54px;flex-wrap:wrap;padding:0 20px;max-width:980px;margin:0 auto}
.nav-tab{background:none;border:none;color:#55556a;padding:6px 14px;border-radius:6px;cursor:pointer;font-size:12px;transition:all .15s;white-space:nowrap}
.nav-tab.active{color:#c8a840;background:#c8a84018}
.nav-tab:hover:not(.active){color:#88889a;background:#ffffff08}
.dir-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}
.also-chip{background:#0d0d1a;border:1px solid #1c1c2c;border-radius:8px;padding:8px 14px;display:inline-flex;gap:10px;align-items:center}
.section-divider{border:none;border-top:1px solid #151525;margin:36px 0}
.slider-group{display:flex;flex-direction:column;gap:5px;min-width:130px}
.slider-label{color:#77778a;font-size:11px;display:flex;justify-content:space-between}
.slider-val{color:#c8a840;font-weight:bold}
.wslider{-webkit-appearance:none;appearance:none;width:100%;height:3px;border-radius:2px;background:#1e1e2e;outline:none;cursor:pointer}
.wslider::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:#c8a840;cursor:pointer}
.wslider::-moz-range-thumb{width:14px;height:14px;border-radius:50%;background:#c8a840;border:none;cursor:pointer}
/* Modal */
.share-banner{background:linear-gradient(135deg,#0e0e1c,#141428);border:1px solid #252535;border-radius:14px;padding:24px 28px;margin-bottom:28px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.share-copy-btn{background:#c8a840;color:#08080f;border:none;border-radius:8px;padding:10px 20px;font-size:13px;font-weight:bold;cursor:pointer;font-family:inherit;transition:opacity .15s;white-space:nowrap}
.share-copy-btn:hover{opacity:.85}
.share-cat-section{margin-bottom:48px}
.modal-bg{display:none;position:fixed;inset:0;background:#000000cc;z-index:999;align-items:center;justify-content:center;padding:20px}
.modal-bg.open{display:flex}
.modal-box{background:#0e0e1c;border:1px solid #252535;border-radius:14px;max-width:560px;width:100%;max-height:90vh;overflow-y:auto;padding:28px}
.modal-close{float:right;background:none;border:none;color:#55556a;font-size:20px;cursor:pointer;line-height:1}
/* Genre bar */
.genre-bar{height:6px;border-radius:3px;background:#c8a840;transition:width .4s ease}
/* Mobile */
@media(max-width:640px){
  .nav-inner{height:auto;padding:8px 12px;gap:6px}
  .nav-inner>div:first-child{width:100%;font-size:12px}
  .nav-tab{padding:5px 10px;font-size:11px}
  .btn-sm{padding:5px 10px;font-size:11px}
  .btn-gold{padding:11px 16px;font-size:14px}
  .dir-grid{grid-template-columns:1fr}
  .slider-group{min-width:calc(50% - 10px)}
  h1{font-size:clamp(28px,6vw,48px)!important}
}
</style>
</head>
<body>

<!-- ══════════════════════════════════ UPLOAD -->
<div id="page-upload" class="page active">
  <div style="text-align:center;padding:52px 20px 36px;border-bottom:1px solid #181828">
    <div class="eyebrow">Letterboxd · Crew &amp; Cast Analysis</div>
    <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(32px,7vw,64px);font-weight:900;margin:10px 0 12px;line-height:1.05;color:#f0e8d8">
      Mount Rushmore<br/><em style="color:#c8a840;font-size:.82em">of Cinema</em>
    </h1>
    <p style="color:#77778a;max-width:440px;margin:0 auto;line-height:1.75;font-size:14px">
      Upload your Letterboxd export to find the four directors, writers, and actors who define your taste.
    </p>
  </div>
  <div style="max-width:660px;margin:0 auto;padding:32px 20px">
    <div style="margin-bottom:24px">
      <div class="eyebrow" style="margin-bottom:14px">How to get your data</div>
      <div style="display:flex;flex-direction:column;gap:11px">
        <div style="display:flex;gap:14px"><span style="color:#c8a84033;font-size:20px;font-weight:900;width:28px;flex-shrink:0;font-family:'Playfair Display',serif">01</span><div><b style="color:#e0d8c8;font-size:14px">letterboxd.com/settings</b><div style="color:#55556a;font-size:13px;margin-top:1px">Open account settings</div></div></div>
        <div style="display:flex;gap:14px"><span style="color:#c8a84033;font-size:20px;font-weight:900;width:28px;flex-shrink:0;font-family:'Playfair Display',serif">02</span><div><b style="color:#e0d8c8;font-size:14px">Import &amp; Export → Export Your Data</b><div style="color:#55556a;font-size:13px;margin-top:1px">Downloads a .zip — extract it</div></div></div>
        <div style="display:flex;gap:14px"><span style="color:#c8a84033;font-size:20px;font-weight:900;width:28px;flex-shrink:0;font-family:'Playfair Display',serif">03</span><div><b style="color:#e0d8c8;font-size:14px">Upload diary.csv and/or ratings.csv</b><div style="color:#55556a;font-size:13px;margin-top:1px">Both = best coverage. Or drop a saved .json to skip lookup.</div></div></div>
      </div>
    </div>
    <div id="drop-zone" class="drop-zone" onclick="document.getElementById('file-input').click()">
      <div style="font-size:26px;margin-bottom:10px">🎬</div>
      <div id="drop-label" style="color:#e0d8c8;font-size:15px;margin-bottom:4px">Drop files here or click to browse</div>
      <div style="color:#44445a;font-size:12px">diary.csv · ratings.csv · or a previously saved .json data file</div>
      <input id="file-input" type="file" accept=".csv,.json" multiple style="display:none" onchange="handleFileInput(this.files)"/>
    </div>
    <!-- Config -->
    <div style="margin-top:18px;background:#0e0e1c;border:1px solid #1a1a2c;border-radius:12px;overflow:hidden">
      <button onclick="toggleConfig()" style="width:100%;background:none;border:none;color:#66667a;padding:14px 18px;cursor:pointer;text-align:left;display:flex;justify-content:space-between;align-items:center;font-size:13px">
        <span>⚙ API Key Setup <span id="config-status-badge"></span></span>
        <span id="config-chevron">▸</span>
      </button>
      <div id="config-panel" style="display:none;padding:0 18px 18px">
        <div style="color:#55556a;font-size:12px;line-height:1.65;margin-bottom:14px;padding-top:4px">
          The built-in database covers the top ~10,000 films and works without any key.
          Add a free <b style="color:#c8c0b0">TMDB</b> key to look up obscure or foreign films not in the database.
          Get one at <span style="color:#c8a840">themoviedb.org/settings/api</span>.
        </div>
        <div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
            <label style="color:#c8c0b0;font-size:13px;font-weight:bold">TMDB API Key <span style="color:#66667a;font-size:11px">(optional)</span></label>
            <span id="tmdb-saved-badge" style="display:none;color:#4a9a4a;font-size:11px">✓ saved</span>
          </div>
          <div style="display:flex;gap:8px">
            <input id="tmdb-key-input" class="input-field" type="password" placeholder="Paste TMDB API key…" style="flex:1"/>
            <button class="btn-ghost btn-sm" onclick="saveKey('tmdb')">Save</button>
            <button class="btn-ghost btn-sm" onclick="clearKey('tmdb')" style="color:#553333;border-color:#2a1a1a">Clear</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════ NAMING -->
<div id="page-naming" class="page">
  <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px">
    <div style="max-width:440px;width:100%;animation:fadeUp .3s ease">
      <div class="eyebrow" style="margin-bottom:12px">One quick thing</div>
      <h2 style="font-family:'Playfair Display',Georgia,serif;font-size:28px;margin:0 0 10px;color:#f0e8d8;font-weight:700">What's your name?</h2>
      <p style="color:#66667a;font-size:14px;line-height:1.7;margin-bottom:28px">We'll personalize the graphic — <em style="color:#88889a">Marty's Mount Rushmore</em>. Hit Enter or leave blank to skip.</p>
      <input id="name-input" class="input-field" style="margin-bottom:12px" placeholder="Your first name…" onkeydown="if(event.key==='Enter')startAnalysis()"/>
      <div style="display:flex;gap:10px">
        <button class="btn-gold" style="flex:1" id="analyze-btn" onclick="startAnalysis()">Analyze →</button>
        <button class="btn-ghost" onclick="showPage('page-upload')">Back</button>
      </div>
      <p id="naming-files" style="color:#2a2a3a;font-size:11px;margin-top:12px;text-align:center"></p>
      <div id="lookup-badge" style="margin-top:10px;text-align:center"></div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════ PROCESSING -->
<div id="page-processing" class="page">
  <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px">
    <div style="text-align:center;max-width:440px;width:100%">
      <div class="spinner"></div>
      <div id="proc-title" style="color:#c8a840;font-family:'Playfair Display',Georgia,serif;font-size:18px;margin-bottom:12px">Sculpting your mountain…</div>
      <div id="proc-msg" style="color:#55556a;font-size:13px;line-height:1.6;margin-bottom:28px;min-height:44px"></div>
      <div class="progress-bar"><div class="progress-fill" id="prog-fill" style="width:0%"></div></div>
      <div id="prog-pct" style="color:#2a2a42;font-size:11px;margin-top:10px">0%</div>
      <button class="btn-ghost btn-sm" style="margin-top:22px" onclick="cancelAnalysis()">Cancel</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════ ERROR -->
<div id="page-error" class="page">
  <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px">
    <div style="text-align:center;max-width:440px">
      <div style="font-size:36px;margin-bottom:20px">⚠️</div>
      <h3 style="font-family:'Playfair Display',Georgia,serif;color:#f0e8d8;margin:0 0 14px;font-size:22px">Something went wrong</h3>
      <p id="err-msg" style="color:#77778a;font-size:14px;line-height:1.75;margin-bottom:30px"></p>
      <div style="display:flex;gap:10px;justify-content:center">
        <button class="btn-gold" onclick="showPage('page-upload')">Try Again</button>
        <button class="btn-ghost" onclick="showPage('page-upload');toggleConfig(true)">Check API Keys</button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════ RESULTS -->
<div id="page-results" class="page">
  <div class="nav">
    <div class="nav-inner">
      <div style="color:#c8a840;font-size:13px;font-weight:bold;letter-spacing:.5px;flex-shrink:0" id="nav-title">My Mount Rushmore</div>
      <div style="display:flex;gap:2px">
        <button class="nav-tab active" id="tab-btn-directors" onclick="switchCat('directors')">🎬 Directors</button>
        <button class="nav-tab" id="tab-btn-writers" onclick="switchCat('writers')">✍️ Writers</button>
        <button class="nav-tab" id="tab-btn-actors" onclick="switchCat('actors')">🎭 Actors</button>
      </div>
      <div style="flex:1"></div>
      <div style="display:flex;gap:6px;flex-shrink:0">
        <button class="btn-gold btn-sm" onclick="shareResults()">🔗 Share</button>
        <button class="btn-ghost btn-sm" onclick="downloadPNG()">↓ PNG</button>
        <button class="btn-ghost btn-sm" onclick="exportCache()">↓ Save Data</button>
        <button class="btn-ghost btn-sm" onclick="openModal()">? How</button>
        <button class="btn-ghost btn-sm" onclick="toggleWeights()">⚖ Settings</button>
        <button class="btn-ghost btn-sm" onclick="resetApp()">✕</button>
      </div>
    </div>
    <!-- Weight sliders panel -->
    <div id="weights-panel" style="display:none;background:#0a0a14;border-top:1px solid #1a1a2a;padding:14px 20px">
      <div style="max-width:980px;margin:0 auto">
        <div style="display:flex;gap:24px;flex-wrap:wrap;align-items:flex-start">
          <div style="color:#55556a;font-size:11px;padding-top:16px;flex-shrink:0">Scoring weights<br/><span id="weights-total-badge" style="color:#c8a840"></span></div>
          <div style="flex:1;display:flex;gap:20px;flex-wrap:wrap;min-width:0">
            <div class="slider-group">
              <div class="slider-label">Avg Rating <span id="lbl-avgRating" class="slider-val">45%</span></div>
              <input type="range" min="0" max="100" value="45" id="sl-avgRating" class="wslider" oninput="onSlider('avgRating',this.value)"/>
            </div>
            <div class="slider-group">
              <div class="slider-label">Films Seen <span id="lbl-filmCount" class="slider-val">40%</span></div>
              <input type="range" min="0" max="100" value="40" id="sl-filmCount" class="wslider" oninput="onSlider('filmCount',this.value)"/>
            </div>
            <div class="slider-group">
              <div class="slider-label">Top 3 Avg <span id="lbl-top3Score" class="slider-val">7%</span></div>
              <input type="range" min="0" max="100" value="7" id="sl-top3Score" class="wslider" oninput="onSlider('top3Score',this.value)"/>
            </div>
            <div class="slider-group">
              <div class="slider-label">Rewatches <span id="lbl-rewatches" class="slider-val">8%</span></div>
              <input type="range" min="0" max="100" value="8" id="sl-rewatches" class="wslider" oninput="onSlider('rewatches',this.value)"/>
            </div>
          </div>
          <button class="btn-ghost btn-sm" onclick="resetWeights()" style="margin-top:14px;flex-shrink:0">Reset</button>
          <!-- Min films + top actors -->
          <div style="display:flex;gap:20px;flex-wrap:wrap;border-left:1px solid #1e1e2e;padding-left:24px;margin-top:2px">
            <div class="slider-group" style="min-width:160px">
              <div class="slider-label">Min films to qualify <span id="lbl-minFilms" class="slider-val">3</span></div>
              <input type="range" min="1" max="10" value="3" id="sl-minFilms" class="wslider" oninput="onSettingSlider('minFilms',this.value)"/>
            </div>
            <div class="slider-group" style="min-width:160px">
              <div class="slider-label">Actors counted per film <span id="lbl-topActors" class="slider-val">5</span></div>
              <input type="range" min="1" max="10" value="5" id="sl-topActors" class="wslider" oninput="onSettingSlider('topActors',this.value)"/>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Genre strip -->
  <div id="genre-strip" style="display:none;background:#080810;border-bottom:1px solid #111120;padding:14px 0">
    <div class="wrap">
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <span style="color:#44445a;font-size:10px;letter-spacing:3px;text-transform:uppercase;flex-shrink:0">Top Genres</span>
        <div id="genre-chips" style="display:flex;gap:8px;flex-wrap:wrap"></div>
      </div>
    </div>
  </div>

  <!-- Data quality banners -->
  <div id="data-quality-banner"></div>

  <!-- Director / Writer / Actor category panels (shared structure, toggled) -->
  <div id="cat-directors" class="wrap" style="padding-top:28px;padding-bottom:60px"></div>
  <div id="cat-writers"   class="wrap" style="padding-top:28px;padding-bottom:60px;display:none"></div>
  <div id="cat-actors"    class="wrap" style="padding-top:28px;padding-bottom:60px;display:none"></div>
</div>

<script>
// ─── Constants ────────────────────────────────────────────────────────────────
let WEIGHTS = { avgRating:.45, filmCount:.40, top3Score:.07, rewatches:.08 };
let MIN_FILMS = 3, TOP_ACTORS = 5;
const TMDB_CONCURRENCY = 4;
const RANK_COLORS = ['#ffd700','#d4d4d4','#cd7f32','#9999bb'];
const CAT_LABELS  = { directors:'Directors', writers:'Writers', actors:'Actors' };
const CAT_ICONS   = { directors:'🎬', writers:'✍️', actors:'🎭' };
const TMDB_GENRES = {28:'Action',12:'Adventure',16:'Animation',35:'Comedy',80:'Crime',99:'Documentary',18:'Drama',10751:'Family',14:'Fantasy',36:'History',27:'Horror',10402:'Music',9648:'Mystery',10749:'Romance',878:'Sci-Fi',53:'Thriller',10752:'War',37:'Western'};

// ─── Built-in Film Database ───────────────────────────────────────────────────
// Populated by build-db.js. Format per entry: "Director|Writer1,Writer2|Actor1,...,Actor10|Genre1,Genre2"
// FILM_DB_BEGIN
const FILM_DB = {
  "Apex||2026":"Baltasar Kormákur|Jeremy Robbins|Charlize Theron,Taron Egerton,Eric Bana,Caitlin Stasey,Bessie Holland,Zachary Garred,Matt Whelan,Rob Carlton,Aaron Pedersen,Duncan Fellows|Action,Thriller",
  "The Super Mario Galaxy Movie||2026":"Michael Jelenic|Matthew Fogel|Chris Pratt,Charlie Day,Anya Taylor-Joy,Jack Black,Keegan-Michael Key,Benny Safdie,Donald Glover,Luis Guzmán,Issa Rae,Kevin Michael Richardson|Family,Comedy,Adventure,Fantasy,Animation",
  "Your Heart Will Be Broken||2026":"Mikhail Vaynberg||Daniel Vegas,Veronika Zhuravleva,Ivan Trushin,Maksim Saprykin,Alya Mayer,Evgeniya Loza,Pavel Kuzmin,Alexandra Tikhonova,Margarita Dyachenkova,Anton Solomatin|Romance,Drama",
  "Michael||2026":"Antoine Fuqua|John Logan|Jaafar Jackson,Colman Domingo,Nia Long,Juliano Krue Valdi,KeiLyn Durrel Jones,Miles Teller,Kendrick Sampson,Joseph David-Jones,Jamal Henderson,Rhyan Hill|Music,Drama",
  "Send Help||2026":"Sam Raimi|Damian Shannon,Mark Swift|Rachel McAdams,Dylan O'Brien,Edyll Ismail,Dennis Haysbert,Xavier Samuel,Chris Pang,Thaneth Warakulnukroh,Emma Raimi,Kristy Best,Francesca Waters|Horror,Thriller,Comedy",
  "They Will Kill You||2026":"Kirill Sokolov|Kirill Sokolov,Alex Litvak|Zazie Beetz,Patricia Arquette,Myha'la,Paterson Joseph,Tom Felton,Heather Graham,Willie Ludik,David Viviers,Gabe Gabriel,Viktoriya Korotkova|Action,Comedy,Horror",
  "Avatar Aang: The Last Airbender||2026":"Lauren Montgomery|Tim Hedrick,Christopher L. Yost,Bryan Konietzko|Eric Nam,Dave Bautista,Jessica Matten,Román Zaragoza,Steven Yeun,Dionne Quan,Dee Bradley Baker,Freida Pinto,Ke Huy Quan,Taika Waititi|Animation,Action,Adventure,Fantasy",
  "Hoppers||2026":"Daniel Chong|Jesse Andrews,Daniel Chong|Piper Curda,Bobby Moynihan,Jon Hamm,Kathy Najimy,Dave Franco,Eduardo Franco,Aparna Nancherla,Tom Law,Sam Richardson,Melissa Villaseñor|Adventure,Animation,Comedy,Family,Science Fiction",
  "Avatar: Fire and Ash||2025":"James Cameron|James Cameron,Shane Salerno,Amanda Silver|Sam Worthington,Zoe Saldaña,Sigourney Weaver,Stephen Lang,Oona Chaplin,Jack Champion,Kate Winslet,Cliff Curtis,Joel David Moore,CCH Pounder|Science Fiction,Adventure,Fantasy",
  "Vengeance||2026":"Rodrigo Valdes|Matt Bosack,Yalun Tu,Daniel Krauze|Omar Chaparro,Alejandro Speitzer,Paola Nuñez,Natalia Solián,Luis Alberti,Iazua Larios,Lizeth Selene,Gustavo Sánchez Parra,Vasil Simeonov,Manuel Cruz Vivas|Action,Thriller",
